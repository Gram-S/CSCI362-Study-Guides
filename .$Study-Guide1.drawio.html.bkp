ell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-2\&quot; value=\&quot;&amp;lt;div&amp;gt;&amp;lt;br&amp;gt;&amp;lt;/div&amp;gt;&amp;lt;div&amp;gt;To store a &amp;lt;b&amp;gt;binary value &amp;lt;/b&amp;gt;we use a &amp;lt;b&amp;gt;DDF&amp;lt;/b&amp;gt;, which outputs its previous input, aka &amp;lt;b&amp;gt;out(t+1) = in(t)&amp;lt;/b&amp;gt;.&amp;amp;nbsp;&amp;lt;span style=&amp;quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&amp;quot;&amp;gt;We use a looping &amp;lt;/span&amp;gt;&amp;lt;b style=&amp;quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&amp;quot;&amp;gt;Mux &amp;lt;/b&amp;gt;&amp;lt;span style=&amp;quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&amp;quot;&amp;gt;gate along with a &amp;lt;/span&amp;gt;&amp;lt;b style=&amp;quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&amp;quot;&amp;gt;DDF&amp;amp;nbsp;&amp;lt;/b&amp;gt;&amp;lt;span style=&amp;quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&amp;quot;&amp;gt;to make a&amp;amp;nbsp;&amp;lt;/span&amp;gt;&amp;lt;b style=&amp;quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&amp;quot;&amp;gt;bit&amp;lt;/b&amp;gt;&amp;lt;span style=&amp;quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&amp;quot;&amp;gt;.&amp;lt;/span&amp;gt;&amp;lt;/div&amp;gt;\&quot; style=\&quot;text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;\&quot; parent=\&quot;vTmvLF_deM2W3OOhQ7cJ-23\&quot; vertex=\&quot;1\&quot;&gt;&lt;mxGeometry y=\&quot;15\&quot; width=\&quot;302\&quot; height=\&quot;55\&quot; as=\&quot;geometry\&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-9\&quot; value=\&quot;\&quot; style=\&quot;group\&quot; parent=\&quot;vTmvLF_deM2W3OOhQ7cJ-23\&quot; vertex=\&quot;1\&quot; conn