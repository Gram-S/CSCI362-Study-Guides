t;&lt;Array as=\&quot;points\&quot;&gt;&lt;mxPoint x=\&quot;189\&quot; y=\&quot;40\&quot;/&gt;&lt;mxPoint x=\&quot;189\&quot; y=\&quot;78\&quot;/&gt;&lt;mxPoint x=\&quot;13\&quot; y=\&quot;78\&quot;/&gt;&lt;mxPoint x=\&quot;13\&quot; y=\&quot;53\&quot;/&gt;&lt;mxPoint x=\&quot;58\&quot; y=\&quot;53\&quot;/&gt;&lt;/Array&gt;&lt;/mxGeometry&gt;&lt;/mxCell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-5\&quot; value=\&quot;DDF\&quot; style=\&quot;rounded=0;whiteSpace=wrap;html=1;\&quot; parent=\&quot;vTmvLF_deM2W3OOhQ7cJ-11\&quot; vertex=\&quot;1\&quot;&gt;&lt;mxGeometry x=\&quot;121\&quot; y=\&quot;25.25\&quot; width=\&quot;59\&quot; height=\&quot;29.5\&quot; as=\&quot;geometry\&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-10\&quot; value=\&quot;\&quot; style=\&quot;triangle;whiteSpace=wrap;html=1;rotation=-90;\&quot; parent=\&quot;vTmvLF_deM2W3OOhQ7cJ-11\&quot; vertex=\&quot;1\&quot;&gt;&lt;mxGeometry x=\&quot;146.6897010869565\&quot; y=\&quot;46.620000000000005\&quot; width=\&quot;7.63\&quot; height=\&quot;8.75\&quot; as=\&quot;geometry\&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-14\&quot; value=\&quot;Bit\&quot; style=\&quot;text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;\&quot; parent=\&quot;vTmvLF_deM2W3OOhQ7cJ-23\&quot; vertex=\&quot;1\&quot;&gt;&lt;mxGeometry x=\&quot;110\&quot; y=\&quot;177\&quot; width=\&quot;96\&quot; height=\&quot;14\&quot; as=\&quot;geometry\&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-79\&quot; value=\&quot;\&quot; style=\&quot;group\&quot; parent=\&quot;1\&quot; vertex=\&quot;1\&quot; connectable=\&quot;0\&quot;&gt;&lt;mxGeometry x=\&quot;383\&quot; y=\&quot;585\&quot; width=\&quot;451\&quot; height=\&quot;425\&quot; as=\&quot;geometry\&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-24\&quot; value=\&quot;&amp;lt;span style=&amp;quot;font-size: 16px;&amp;quot;&amp;gt;&amp;lt;i&amp;gt;Registers &amp;amp;amp; Ram&amp;lt;/i&amp;gt;&amp;lt;/span&amp;gt;\&quot; style=\&quot;text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;\&quot; parent=\&quot;vTmvLF_deM2W3OOhQ7cJ-79\&quot; vertex=\&quot;1\&quot;&gt;&lt;mxGeometry x=\&quot;7\&quot; width=\&quot;126\&quot; height=\&quot;30\&quot; as=\&quot;geometry\&quot;/&gt;&lt;/mxCell&gt;&lt;mxCell id=\&quot;vTmvLF_deM2W3OOhQ7cJ-41\&quot; value=\&quot;A &amp;lt;b&amp;gt;register&amp;lt;/b&amp;gt;&amp;amp;nbsp;is &amp;lt;b&amp;gt;16 bits &amp;lt;/b&amp;gt;all sharing the same &amp;lt;b&amp;gt;load&amp;lt;/b&amp;gt; bit.&amp;amp;nbsp; A &amp;lt;b&amp;gt;Ram &amp;lt;/b&amp;gt;chip additionally takes in an &amp;lt;b&amp;gt;address&amp;lt;/b&amp;gt;&amp;amp;nbsp;which is used in combination with a &amp;lt;b&amp;gt;DMux8way&amp;lt;/b&amp;gt; to select a &amp;lt;b&amp;gt;register/subram &amp;lt;/b&amp;gt;to &amp;lt;b&amp;gt;load&amp;lt;/b&amp;gt;. For a &amp;lt;b&amp;gt;RAMn&amp;lt;/b&amp;gt;, the&amp;amp;nbsp;&amp;lt;b&amp;gt;address &amp;lt;/b&amp;gt;is &amp;lt;b&amp;gt;log&amp;lt;sub&amp;gt;2&amp;lt;/sub&amp;gt;n &amp;lt;/b&amp;gt;bits. &amp;lt;b&amp;gt;n &amp;lt;/b&amp;gt;is commonly a multiple of 8, for example, &amp;lt;b&amp;gt;RAM64&amp;lt;/b&amp;gt; is made of &amp;lt;b&amp;gt;8 RAM8s&amp;lt;/b&amp;gt;.&amp;amp;nbsp;&amp;amp;nbsp;&amp;lt;span style=&amp;quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&amp;quot;&amp;gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20value%3D%22%22%20style%3D%22group%22%20vertex%3D%221%22%20connectable%3D%220%22%20parent%3D%221%22%3E%3CmxGeometry%20x%3D%2222%22%20y%3D%22585%22%20width%3D%22305%22%20height%3D%22225%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3CmxCell%20id%3D%223%22%20value%3D%22%26lt%3Bspan%20style%3D%26quot%3Bfont-size%3A%2016px%3B%26quot%3B%26gt%3B%26lt%3Bi%26gt%3BBits%26lt%3B%2Fi%26gt%3B%26